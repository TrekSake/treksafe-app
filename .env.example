# =============================================================================
# TrekSafe — Variables de entorno (referencia)
# =============================================================================
# Copia las secciones correspondientes a backend/.env y frontend/.env
# Nunca subas archivos .env al repositorio.
# =============================================================================

# --- Backend (backend/.env) ---

# Servidor
NODE_ENV=development
PORT=3000
API_PREFIX=/api

# Supabase — usar service_role o DATABASE_URL (bypass RLS). NUNCA anon key.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Session pooler (5432) — recomendado para Express. Transaction (6543) solo serverless.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# JWT propio (HU-02) — generar con: openssl rand -base64 64
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=24h

# Cifrado AES-256 ficha médica (Sprint 2, Ley N° 29733) — obligatorio
MEDICAL_ENCRYPTION_KEY=change-me-32-byte-key-for-aes-256!!

# SMTP alertas (Sprint 4)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=TrekSafe Alertas <alertas@treksafe.pe>

# Alternativa a SMTP: API REST de Brevo (xkeysib-...). Tiene prioridad si está definida.
BREVO_API_KEY=

# En desarrollo: si SMTP/API falla (p. ej. IP no autorizada en Brevo), registrar en consola
# En producción usar MAIL_DEV_FALLBACK=false
MAIL_DEV_FALLBACK=true

# Cron motor de plazos (Sprint 3) — intervalo en ms
CRON_INTERVAL_MS=60000
CORS_ORIGIN=http://localhost:5173

# --- Producción (Fly.io secrets / Vercel env) ---
# NODE_ENV=production
# MAIL_DEV_FALLBACK=false
# CORS_ORIGIN=https://YOUR_APP.vercel.app
# VITE_API_URL=https://treksafe-api.fly.dev/api   # build-time en Vercel

# --- Frontend (frontend/.env) ---

# URL del backend REST. Sin claves de Supabase en el cliente.
VITE_API_URL=http://localhost:3000/api
